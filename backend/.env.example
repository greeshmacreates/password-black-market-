# Server Configuration
PORT=5000
NODE_ENV=production

# CORS Configuration - Set to your frontend domain in production
CORS_ORIGIN=https://yourdomain.com

# MongoDB Connection String
# Local: mongodb://localhost:27017/password_black_market
# Atlas: mongodb+srv://username:password@cluster.mongodb.net/database
MONGO_URI=mongodb://localhost:27017/password_black_market

# JWT Secret - IMPORTANT: Change this to a secure random string in production
# Generate: openssl rand -base64 32
JWT_SECRET=change-this-to-a-secure-random-string

# Firebase Authentication
FIREBASE_AUTH_DISABLED=false
# Required for full Firebase email/password login flow (Web API key from Firebase project settings)
FIREBASE_WEB_API_KEY=your-firebase-web-api-key
# FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"..."}
